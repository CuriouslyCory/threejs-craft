// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
    // Further reading:
    // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
    // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
    //
    // Prisma 7: the connection URL lives in `prisma.config.ts` (for the CLI) and is
    // passed to `PrismaClient` via the driver adapter (see `src/server/db.ts`).
}

model Post {
    id        Int      @id @default(autoincrement())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    createdBy   User   @relation(fields: [createdById], references: [id])
    createdById String

    @@index([name])
}

// Necessary for Next auth
model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String? // @db.Text
    access_token             String? // @db.Text
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String? // @db.Text
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String      @id @default(cuid())
    name          String?
    email         String?     @unique
    emailVerified DateTime?
    image         String?
    accounts      Account[]
    sessions      Session[]
    posts         Post[]
    savedWorld    SavedWorld?
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

// Per-user world persistence (#19): exactly one active `SavedWorld` per
// user, storing only the seed plus its edit-deltas — see
// `docs/adr/0001-multiplayer-persistence-edit-deltas.md` for the storage
// model this implements and `docs/adr/0002-per-user-world-persistence.md`
// for why this is single-active-world-per-user rather than many worlds.
model SavedWorld {
    id        String       @id @default(cuid())
    userId    String       @unique
    seed      String
    version   Int          @default(1)
    updatedAt DateTime     @updatedAt
    user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
    deltas    ChunkDelta[]
}

// One row per touched chunk (composite PK enforces this uniqueness), storing
// a compact sparse diff against that chunk's seeded base — see
// `src/game/persistence/chunk-delta.ts` for the encoding and
// `src/game/persistence/world-delta.ts` for how deltas are replayed.
model ChunkDelta {
    savedWorldId String
    chunkKey     String
    data         Bytes
    savedWorld   SavedWorld @relation(fields: [savedWorldId], references: [id], onDelete: Cascade)

    @@id([savedWorldId, chunkKey])
}
